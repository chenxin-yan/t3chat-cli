{
  "name": "t3chat-cli",
  "version": "0.0.0",
  "type": "module",
  "description": "A CLI built with Crust",
  "bin": {
    "chat": "dist/cli"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "crust build",
    "start": "./dist/cli",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@crustjs/core": "latest",
    "@crustjs/plugins": "latest"
  },
  "devDependencies": {
    "@crustjs/crust": "^0.0.9",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
