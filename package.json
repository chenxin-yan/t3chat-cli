{
  "name": "@cyanlabs/t3chat",
  "version": "0.0.3",
  "type": "module",
  "description": "CLI wrapper for t3.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/chenxin-yan/t3chat-cli"
  },
  "bin": {
    "chat": "dist/cli"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "crust build",
    "start": "./dist/cli",
    "check:types": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@crustjs/core": "^0.0.8",
    "@crustjs/plugins": "^0.0.9",
    "@crustjs/prompts": "^0.0.4",
    "@crustjs/skills": "^0.0.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@crustjs/crust": "^0.0.12",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
